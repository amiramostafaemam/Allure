{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "noUnusedLocals": false,
    "noUnusedParameters": true,
    
  },
  "include": ["src/**/*.ts", "drizzle.config.ts"],
  "exclude": ["drizzle.config.ts","node_modules", "dist"]
}